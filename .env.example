# ── Anthropic ──────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_key_here

# ── JSearch (RapidAPI) — live job search across LinkedIn/Indeed/Glassdoor ──
# Get key at: rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
JSEARCH_API_KEY=your_key_here

# ── OpenAI (embeddings + Whisper) ─────────────────────────────────────
OPENAI_API_KEY=your_key_here

# ── Supabase ──────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_KEY=your_service_key

# ── Redis (for Celery) ────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Gmail OAuth ───────────────────────────────────────────────────────
GMAIL_CLIENT_ID=your_client_id
GMAIL_CLIENT_SECRET=your_client_secret
GMAIL_REDIRECT_URI=http://localhost:8000/api/auth/callback/gmail

# ── ChromaDB ──────────────────────────────────────────────────────────
CHROMA_PERSIST_PATH=./data/chroma

# ── Database ──────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./data/career_copilot.db

# ── ElevenLabs (TTS in Coach) ─────────────────────────────────────────
ELEVENLABS_API_KEY=your_key_here

# ── App settings ──────────────────────────────────────────────────────
ENVIRONMENT=development          # set to "production" on Render
DEBUG=true
CORS_ORIGINS=http://localhost:5173   # comma-separate multiple; add your Vercel URL in prod
WEEKLY_PLANNER_CRON=0 18 * * 0
