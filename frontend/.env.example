# ── Supabase (get from: supabase.com → project → Settings → API) ──────
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...   # anon/public key — safe to expose

# ── Backend API URL ────────────────────────────────────────────────────
# Leave empty for local dev (Vite proxy handles /api → localhost:8000)
# Set to your Render URL in production:
# VITE_API_URL=https://landit-backend.onrender.com
VITE_API_URL=
